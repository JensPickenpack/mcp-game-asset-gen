# API Keys for Asset Generation
# Copy this file to .env and fill in your actual API keys

# PPQ.ai API Key - Unified API used for image, video and audio generation (recommended)
# Supports image models: gpt-image-1, nano-banana-pro, flux-2-pro/flex, flux-kontext-pro/max, flux-2-pro-i2i
# Also used for: text-to-speech and speech-to-text (Deepgram voice/stt via PPQ integration)
# Get yours at: https://ppq.ai/api-keys
PPQ_API_KEY=your_ppq_api_key_here

# FAL.ai API Key - Required for 3D model generation (Trellis, Hunyuan3D, Hunyuan World)
# FAL.ai is kept for high-quality 3D generation; PPQ.ai is used for images/video/audio.
# Get yours at: https://fal.ai/dashboard
FAL_AI_API_KEY=your_fal_ai_api_key_here

# Optional: Set to 'true' to delete generated test artifacts after integration tests
# Default is 'false' (keeps generated files for inspection)
CLEANUP_TEST_FILES=false

# Optional: Comma-separated list of tools to expose via the MCP server
# If not set, all tools will be available. Example:
# ALLOWED_TOOLS=ppqai_generate_image,ppqai_generate_video,generate_texture
# Available tools (current):
# - ppqai_generate_image
# - ppqai_generate_video
# - ppqai_text_to_speech
# - ppqai_transcribe_audio
# - generate_character_sheet
# - generate_character_variation
# - generate_pixel_art_character
# - generate_texture
# - generate_object_sheet
# - image_to_3d_async
ALLOWED_TOOLS=

# Master Style Prompt - automatically prepended to EVERY asset generation prompt.
# Use this to enforce a unified art direction across all generated assets (sprites, textures, videos, 3D refs).
# Template: "All assets for a cohesive [GAME-THEME] game in [STYLE]: unified color palette #HEX1, #HEX2, #HEX3,
#            clean silhouettes, consistent lighting from top-left, game-ready, high readability"
# Example for a cyberpunk pixel-art roguelike:
#   MASTER_STYLE_PROMPT=All assets for a cohesive cyberpunk pixel-art roguelike in retro-futuristic 16-bit style: neon cyan #00FFFF, magenta #FF00FF, deep purple #4B0082, clean silhouette design, consistent lighting from top-left, game-ready, high readability
MASTER_STYLE_PROMPT=

# ImageMagick is required for transparent background conversion in some tools
# Install with: brew install imagemagick (macOS) or apt-get install imagemagick (Ubuntu)
# This enables the `transparentBackground` option in texture and pixel art generation tools

### Notes
# - Images / video / audio: use PPQ.ai (set `PPQ_API_KEY`).
# - 3D models: use FAL.ai. Default model for 3D generation is `hunyuan3d` (best quality).
#   Other 3D options: `trellis` (good for objects), `hunyuan-world` (for scenes/worlds).
# - TTS/STT: PPQ.ai exposes Deepgram voices and Nova STT via the PPQ endpoints; use `PPQ_API_KEY`.